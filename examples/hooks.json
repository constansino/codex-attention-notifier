{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 ~/.codex/hooks/codex_attention_notify.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
